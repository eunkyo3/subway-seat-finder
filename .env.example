# ─────────────────────────────────────────────────────────────
#  지하철 실시간 혼잡 예측 — 환경변수 템플릿
#
#  이 파일을 복사해서 값을 채우세요.
#      cp .env.example .env
#
#  .env 는 .gitignore 로 제외됩니다. 절대 커밋하지 마세요.
# ─────────────────────────────────────────────────────────────

# ── 인증키 ───────────────────────────────────────────────────
# 서울 열린데이터광장은 인증키가 두 종류이고 서로 호환되지 않습니다.
# 일반 키로 실시간 API를 부르면 ERROR-338 이 납니다.

# [필수] 일반 인증키 — 역 마스터·좌표·승하차 통계
#   발급: https://data.seoul.go.kr/together/mypage/actkeyMain.do
#         → "일반 인증키 신청"
SEOUL_API_KEY=

# [선택] 실시간 지하철 인증키 — 열차 위치·도착
#   발급: 위와 같은 페이지의 "실시간 지하철 인증키 신청" (다른 버튼입니다)
#   일 1,000회 한도. 없어도 앱은 뜨며 열차 위치만 비고 나머지는 동작합니다.
SEOUL_REALTIME_API_KEY=

# ── 경로 ─────────────────────────────────────────────────────
# 비워 두면 프로젝트 루트 기준 기본값을 씁니다.
# 도커에서는 compose 가 /app/data 아래로 덮어씁니다.

# DuckDB 파일 위치 (기본: data/subway.duckdb)
SUBWAY_DB_PATH=

# 혼잡도 원본 파일(OA-12928)을 놓는 폴더 (기본: data/raw)
SUBWAY_RAW_DIR=

# 실시간 스냅샷 녹화 폴더 (기본: data/snapshots)
SUBWAY_SNAPSHOT_DIR=

# ── 동작 튜닝 ────────────────────────────────────────────────

# 실시간 API 응답 캐시 수명(초). 일 1,000회 한도를 지키는 장치입니다.
# 짧게 잡을수록 최신이지만 호출을 빨리 소진합니다. (기본: 30)
REALTIME_CACHE_TTL=30

# 이번/다음 열차 혼잡도 차이가 이 값(%p) 미만이면 추천하지 않고
# "비슷함"으로 표시합니다. 몇 %p 차이로 열차를 보내라는 건
# 예측 정밀도를 넘어서는 조언이라 과잉추천을 막습니다. (기본: 8)
SIMILAR_THRESHOLD_PCT=8
